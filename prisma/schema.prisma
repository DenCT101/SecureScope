// Prisma Schema — Single source of truth for your data model
// Docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─── Models ──────────────────────────────────────────────────────

// Scan model — the core entity. No user association in local-first mode.
model Scan {
  id              String          @id @default(uuid())
  url             String
  toolType        ToolType        @default(NIKTO)
  status          ScanStatus      @default(PENDING)
  metadata        Json?
  geminiKey       String?         @map("gemini_key")  // Per-scan BYOK key (never persisted long-term)
  createdAt       DateTime        @default(now()) @map("created_at")
  updatedAt       DateTime        @updatedAt @map("updated_at")
  vulnerabilities Vulnerability[] @relation("ScanVulnerabilities")

  @@map("scans")
}

model Vulnerability {
  id             String   @id @default(uuid())
  scanId         String
  severity       String
  message        String
  rawData        Json     @map("raw_data")
  translatedText String?  @map("translated_text")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  scan Scan @relation("ScanVulnerabilities", fields: [scanId], references: [id], onDelete: Cascade)

  @@map("vulnerabilities")
}

enum ToolType {
  NIKTO
  NMAP
  SEMGREP
}

enum ScanStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  FAILED
}
